# ═══════════════════════════════════════════════
# 报销智能化系统 — 环境变量配置
# 复制此文件为 .env 并填写真实值
# ═══════════════════════════════════════════════

# ── Flask 安全配置 ──
# [必须] Flask Session 签名密钥，生产环境务必设置为随机长字符串
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=请替换为随机生成的64位十六进制密钥
# [可选] 调试模式（生产环境必须为 0 或不设置）
# FLASK_DEBUG=0

# ── DeepSeek API 配置 ──
DEEPSEEK_API_KEY=your_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions   # API 地址
# DEEPSEEK_MODEL=deepseek-v4-flash                               # 模型名称

# ── 数据库配置 ──
# OA_DB_PATH=oa_agent.db                                         # SQLite 数据库路径（默认项目根目录）

# ── OA集成（预留）──
# OA_BASE_URL=https://oa.example.com                             # 泛微 OA API 地址
# OA_TOKEN=your_oa_token_here                                    # OA API Token

# ── 业务参数 ──
# REQUEST_TIMEOUT=120                                            # API 请求超时时间（秒）
# LOG_LEVEL=INFO                                                 # 日志级别
